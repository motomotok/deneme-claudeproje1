{
  "name": "neon-yorunge",
  "version": "1.0.0",
  "description": "Neon Yörünge - tarayıcı tabanlı refleks/arcade oyunu ve Android uygulaması",
  "private": true,
  "scripts": {
    "serve": "npx serve www -l 8080",
    "build:ads": "esbuild src/native-ads.js --bundle --format=iife --outfile=www/native-ads-bundle.js",
    "cap:sync": "npm run build:ads && cap sync android",
    "android:open": "cap open android",
    "android:debug": "cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor-community/admob": "^6.2.0",
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "cordova-plugin-purchase": "^13.18.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.0",
    "esbuild": "^0.28.1"
  }
}
